{
  "uid": "ticketing-red",
  "title": "Ticketing Labs — RED (per endpoint)",
  "tags": ["ticketing-labs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Rate — requests/sec by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (router) (rate(traefik_router_requests_total[1m]))",
          "legendFormat": "{{router}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors — 5xx requests/sec by route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (router) (rate(traefik_router_requests_total{code=~\"5..\"}[1m]))",
          "legendFormat": "{{router}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Duration — p95 seconds by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traefik_service_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
