{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "Ticketing Labs design tokens",
    "description": "One source of truth for colour, spacing, typography, radius and motion. All three client apps consume this file. Values are mirrored from the reference React frontend (frontend/src/styles.css) so the apps look like siblings, not distant cousins.",
    "version": "0.1.0"
  },
  "color": {
    "bg": { "value": "#0f1115", "description": "App background." },
    "surface": { "value": "#1a1e26", "description": "Card / raised surface." },
    "surfaceAlt": { "value": "#232834", "description": "Inputs, secondary buttons." },
    "line": { "value": "#2a2f3a", "description": "Borders and dividers." },
    "text": { "value": "#e6e8ec", "description": "Primary text." },
    "muted": { "value": "#8b93a1", "description": "Secondary / de-emphasised text." },
    "accent": { "value": "#4f8cff", "description": "Primary action, links, held state." },
    "onAccent": { "value": "#ffffff", "description": "Text/icon on top of accent." },
    "ok": { "value": "#3fb950", "description": "Success. Paid, on-sale, admitted." },
    "warn": { "value": "#f0883e", "description": "Warning. Countdown urgency, pending." },
    "err": { "value": "#f85149", "description": "Error. Failed, sold out, declined." }
  },
  "space": {
    "xs": { "value": 4, "unit": "dp" },
    "sm": { "value": 8, "unit": "dp" },
    "md": { "value": 12, "unit": "dp" },
    "lg": { "value": 16, "unit": "dp" },
    "xl": { "value": 20, "unit": "dp" },
    "xxl": { "value": 24, "unit": "dp" }
  },
  "radius": {
    "sm": { "value": 8, "unit": "dp", "description": "Buttons, inputs." },
    "md": { "value": 12, "unit": "dp", "description": "Cards." },
    "pill": { "value": 999, "unit": "dp", "description": "Badges." }
  },
  "typography": {
    "fontFamily": {
      "value": "system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
      "description": "Platform default. Each app maps this to its own system stack."
    },
    "body": { "size": 15, "lineHeight": 1.5, "weight": 400 },
    "title": { "size": 24, "lineHeight": 1.3, "weight": 700 },
    "heading": { "size": 18, "lineHeight": 1.4, "weight": 700 },
    "caption": { "size": 13, "lineHeight": 1.4, "weight": 400 },
    "micro": { "size": 12, "lineHeight": 1.3, "weight": 500 }
  },
  "motion": {
    "spinnerMs": { "value": 800, "description": "Indeterminate spinner rotation period." },
    "skeletonMs": { "value": 1200, "description": "Skeleton shimmer period." },
    "countdownUrgentThresholdMs": { "value": 30000, "description": "Below this the countdown turns warn-coloured." }
  }
}
