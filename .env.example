# Copy to .env and adjust. .env is gitignored; secrets never live in the repo.
# These values are for LOCAL DEVELOPMENT ONLY. Production injects them from a vault.

# --- Which backend the gateway routes to -------------------------------------
# The active backend is selected by a compose profile. Set COMPOSE_PROFILES to one of:
#   go | fastapi | nest   (more land in later phases)
# Compose reads this automatically. Exactly one backend runs and takes the "backend"
# network alias the gateway routes to. Switching backends is this one line.
COMPOSE_PROFILES=go

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=ticketing
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_dev_only
# The app connects as the least-privilege role, not as the superuser above.
APP_DB_USER=ticketing_app
APP_DB_PASSWORD=app_local_dev_only
DATABASE_URL=postgres://ticketing_app:app_local_dev_only@postgres:5432/ticketing?sslmode=disable

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Message broker (RabbitMQ) -----------------------------------------------
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest_local_dev_only
BROKER_URL=amqp://guest:guest_local_dev_only@broker:5672/

# --- Auth --------------------------------------------------------------------
JWT_SECRET=change_me_local_dev_only
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# --- Payment gateway ---------------------------------------------------------
PAYMENT_GATEWAY_URL=http://payment-gateway-fake:9090
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret

# --- Domain behaviour --------------------------------------------------------
RESERVATION_TTL_SECONDS=120
QUEUE_ADMIT_BATCH=50
